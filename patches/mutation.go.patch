 func mutateInt(r *randGen, a *ConstArg, t *IntType) uint64 {
+	// Enhanced OOB-biased mutation logic
+	
+	// Check if this looks like a size/offset/length parameter for OOB testing
+	isOOBCandidate := false
+	if t.RangeEnd > 0 && (t.RangeEnd <= 8192 || t.RangeEnd == math.MaxUint64) {
+		isOOBCandidate = true
+	}
+	
+	if isOOBCandidate && r.nOutOf(1, 2) {
+		// High probability OOB mutations for size/offset parameters
+		switch r.Intn(10) {
+		case 0, 1, 2:
+			// Boundary values: -1, 0, 1
+			switch r.Intn(3) {
+			case 0:
+				return uint64(^uint64(0)) // -1 in two's complement
+			case 1:
+				return 0
+			case 2:
+				return 1
+			}
+		case 3, 4:
+			// Just beyond typical buffer boundaries
+			boundaries := []uint64{255, 256, 257, 511, 512, 513, 1023, 1024, 1025, 2047, 2048, 2049, 4095, 4096, 4097}
+			return boundaries[r.Intn(len(boundaries))]
+		case 5:
+			// Integer overflow candidates
+			switch t.TypeBitSize() {
+			case 8:
+				return 0xFF + uint64(r.Intn(16)) // Overflow 8-bit
+			case 16:
+				return 0xFFFF + uint64(r.Intn(256)) // Overflow 16-bit
+			case 32:
+				return 0xFFFFFFFF + uint64(r.Intn(1024)) // Overflow 32-bit
+			default:
+				return 0x7FFFFFFFFFFFFFFF + uint64(r.Intn(1024)) // Near 64-bit max
+			}
+		case 6, 7:
+			// Large values to trigger OOB
+			switch r.Intn(3) {
+			case 0:
+				return 8192 + uint64(r.Intn(4096)) // Large offset
+			case 1:
+				return 16384 + uint64(r.Intn(8192)) // Very large offset
+			case 2:
+				return uint64(1 << (t.TypeBitSize() - 1)) // Half of max value
+			}
+		case 8:
+			// Power of 2 boundaries +/- 1
+			power := uint64(1 << r.Intn(13)) // 2^0 to 2^12
+			if r.Bool() {
+				return power - 1
+			}
+			return power + 1
+		case 9:
+			// Negative offsets (two's complement)
+			return uint64(^uint64(r.Intn(4096)))
+		}
+	}
+
+	// Default mutation logic
 	switch {
 	case r.nOutOf(1, 3):
 		return a.Val + (uint64(r.Intn(4)) + 1)
 	case r.nOutOf(1, 2):
 		return a.Val - (uint64(r.Intn(4)) + 1)
 	default:
 		return a.Val ^ (1 << uint64(r.Intn(int(t.TypeBitSize()))))
 	}
 }
